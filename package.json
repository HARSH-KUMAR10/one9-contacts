{
  "name": "one9-contact",
  "version": "1.0.0",
  "description": "Mobile-first contact management app",
  "type": "module",
  "main": "backend/src/server.js",
  "scripts": {
    "dev": "nodemon backend/src/server.js",
    "dev:frontend": "cd frontend && npm run dev",
    "build:frontend": "cd frontend && npm run build",
    "build": "npm run build:frontend",
    "serve": "npm run build && npm run dev",
    "start": "npm run serve",
    "install:all": "npm install && cd frontend && npm install --legacy-peer-deps"
  },
  "keywords": [
    "mobile-first",
    "svelte",
    "nodejs",
    "mongodb"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.6.0",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "morgan": "^1.10.0",
    "cookie-parser": "^1.4.6",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
